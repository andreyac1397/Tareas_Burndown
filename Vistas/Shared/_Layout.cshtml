<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proyecto Tareas SCRUM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/estilos.css" rel="stylesheet" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg barra-superior sombra-suave">
        <div class="container">
            <a class="navbar-brand fw-bold text-white" asp-controller="Inicio" asp-action="Index">Proyecto Tareas SCRUM</a>
            <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="menuPrincipal">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Inicio" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Tareas" asp-action="Index">Tareas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Burndown" asp-action="Index">Burndown</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-4">
        <div class="container">
            <small>
                © 2026 Andrey Calderón Vega - Proyecto de Administración de Proyectos Informáticos
                <br>
                Colegio Universitario de Cartago (CUC)
            </small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>